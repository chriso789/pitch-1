{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pitch-crm.ai/schemas/blueprint-importer/blueprint-plan-path.schema.json",
  "title": "BlueprintPlanPath",
  "type": "object",
  "required": ["import_session_id", "path_type", "confidence"],
  "properties": {
    "id": { "type": "string", "format": "uuid" },
    "import_session_id": { "type": "string", "format": "uuid" },
    "source_document_id": { "type": ["string", "null"], "format": "uuid" },
    "path_type": {
      "type": "string",
      "enum": ["report_page","blueprint_sheet","spec_section","user_entry","derived"]
    },
    "file_name": { "type": ["string", "null"] },
    "document_type": { "type": ["string", "null"] },
    "provider": { "type": ["string", "null"] },
    "page_number": { "type": ["integer", "null"] },
    "section_label": { "type": ["string", "null"] },
    "table_label": { "type": ["string", "null"] },
    "diagram_label": { "type": ["string", "null"] },
    "source_text_excerpt": { "type": ["string", "null"] },
    "source_coordinates": { "type": ["object", "null"] },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
  },
  "anyOf": [
    { "required": ["source_document_id"] },
    { "required": ["page_number"] },
    { "required": ["section_label"] },
    { "required": ["table_label"] },
    { "required": ["diagram_label"] },
    { "required": ["source_text_excerpt"] },
    { "required": ["file_name"] }
  ],
  "additionalProperties": false
}
