{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pitch-crm.ai/schemas/blueprint-importer/blueprint-measurement-object.schema.json",
  "title": "BlueprintMeasurementObject",
  "type": "object",
  "required": ["import_session_id", "tenant_id", "measurement_key", "measurement_group", "unit", "confidence"],
  "properties": {
    "id": { "type": "string", "format": "uuid" },
    "import_session_id": { "type": "string", "format": "uuid" },
    "tenant_id": { "type": "string", "format": "uuid" },
    "source_document_id": { "type": ["string", "null"], "format": "uuid" },
    "trade_id": { "type": ["string", "null"] },
    "measurement_key": { "type": "string" },
    "measurement_group": {
      "type": "string",
      "enum": [
        "roof_area","roof_edges","roof_flashing","roof_pitch","roof_penetrations","roof_waste",
        "wall_area","wall_edges","wall_corners","wall_openings","wall_waste","trim","other"
      ]
    },
    "quantity": { "type": ["number", "null"] },
    "unit": {
      "type": "string",
      "enum": ["sqft","lf","count","pitch_ratio","degrees","percent","ratio","unknown"]
    },
    "precision": { "type": ["number", "null"] },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "source_value_raw": { "type": ["string", "null"] },
    "normalized_value": { "type": ["object", "null"] },
    "plan_path_id": { "type": ["string", "null"], "format": "uuid" },
    "page_number": { "type": ["integer", "null"] },
    "metadata": { "type": "object" }
  },
  "additionalProperties": false
}
